NODE_ENV=production
PORT=8080
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Comma-separated list, e.g. https://my-miniapp.vercel.app,https://localhost:3000
CORS_ORIGINS=
# If true, /api/trade allows requests without x-api-key and uses DEFAULT_AGENT_ID.
ALLOW_UNAUTHENTICATED_TRADES=false
DEFAULT_AGENT_ID=

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Polymarket Configuration
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com
# Optional: L2 Credentials (will be derived if missing)
POLYMARKET_L2_API_KEY=
POLYMARKET_L2_API_SECRET=
POLYMARKET_L2_API_PASSPHRASE=
